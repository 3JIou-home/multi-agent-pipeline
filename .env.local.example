# Copy this file to `.env.local` and fill only the variables you want to keep
# personal to your machine. Existing shell environment variables still win.

# Optional: use OpenAI Responses for intake / review / verification.
# OPENAI_API_KEY=
# AGPIPE_STAGE0_BACKEND=responses
# AGPIPE_STAGE_BACKEND=responses-readonly

# Optional: pin the codex binary if it is not on PATH.
# AGPIPE_CODEX_BIN=/opt/homebrew/bin/codex

# Optional: enable Context7 only if you actually have a key.
# CONTEXT7_API_KEY=

# Optional: stop agpipe from editing your global Codex MCP config automatically.
# AGPIPE_DISABLE_MCP_PROVISION=1
